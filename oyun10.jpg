							var StoreDefaults = {"PartnerEventStore":[{"gid":"715655868018854130","clan_steamid":"103582791475178324","event_name":"Happy PEAKversary!\u00a0","event_type":28,"appid":3527290,"server_address":null,"server_password":null,"rtime32_start_time":1781620800,"rtime32_end_time":1781623260,"comment_count":0,"creator_steamid":"0","last_update_steamid":"0","event_notes":"see announcement body","jsondata":"{\"localized_subtitle\":[\"One year of PEAK and a small teaser\",null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_summary\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_title_image\":[\"3c82bbc4a09cdd70b4a4b37629e4d70e2228c6f9.png\",null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_capsule_image\":[\"8170f36dac68787f41b67905cc023ee024eb2835.png\",null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"bSaleEnabled\":false,\"sale_show_creator\":false,\"sale_sections\":[],\"sale_browsemore_text\":\"\",\"sale_browsemore_url\":\"\",\"sale_browsemore_color\":\"\",\"sale_browsemore_bgcolor\":\"\",\"localized_sale_header\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_sale_overlay\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_sale_product_banner\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_sale_product_mobile_banner\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_sale_logo\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"sale_font\":\"\",\"sale_background_color\":\"\",\"sale_header_offset\":530,\"referenced_appids\":[],\"bBroadcastEnabled\":false,\"broadcastChatSetting\":\"hide\",\"default_broadcast_title\":\"#Broadcast_default_title_dev\",\"localized_broadcast_title\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_broadcast_left_image\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_broadcast_right_image\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"broadcast_whitelist\":[],\"bScheduleEnabled\":false,\"scheduleEntries\":[]}","announcement_body":{"gid":"715655868018854131","clanid":"45656916","posterid":"0","headline":"Happy PEAKversary!\u00a0","posttime":1781620835,"updatetime":1781620835,"body":"[h2]Hey Scouts! \u02d0PEAKsalute\u02d0[\/h2][p][\/p][h3]We cannot believe it\u2019s been a full year since we launched PEAK, and what a year it has been.[\/h3][p][\/p][p][img src=\"{STEAM_CLAN_IMAGE}\/45656916\/8170f36dac68787f41b67905cc023ee024eb2835.png\"][\/img][\/p][p] [\/p][p][b]When Landfall and Aggro Crab set out to make a game together, we never imagined the heights it would take us to, from the one-month game jam to millions of players and a The Game Awards nomination![\/b] [img src=\"{STEAM_CLAN_IMAGE}\/45656916\/d88d9876540d6e38391cc4e5c79fcf60a36c78bb.png\"][\/img][\/p][p][b]It\u2019s been truly life-changing for both teams, so thank you all for being on this journey to the peak with us. It means a lot[\/b] \u02d0PEAKbingbong\u02d0[\/p][p][img src=\"{STEAM_CLAN_IMAGE}\/45656916\/b2203e8db3365c1fda7a511617a5c1c335397d96.gif\"][\/img][\/p][p][b]We\u2019re currently working on the last biome, which will swap with Caldera and the Kiln! It needs a bit more work, but we\u2019re so excited to release it later this year. [\/b][\/p][p][\/p][p][b]Here's a little teaser for a piece of luggage that will accompany the next update. [\/b][\/p][p]\n[img src=\"{STEAM_CLAN_IMAGE}\/45656916\/4ab91db4e840aa154a6eaaf4d9d686a54c647412.gif\"][\/img][\/p][h3]Thank you all for being PEAK![\/h3][p][\/p][h2]\/The PEAK Team[\/h2][p][\/p][p][\/p][p]BTW if you're looking for some PEAK merch, Mighty Merch is doing an [url=\"http:\/\/mightymerch.store\/collections\/peak\"]anniversary sale[\/url]![\/p][p]\n[\/p]","commentcount":311,"tags":["mod_reviewed","ModAct_1691520782_1781622142_0"],"language":0,"hidden":0,"forum_topic_id":"569289127298899551","event_gid":"715655868018854130","voteupcount":12541,"votedowncount":125,"ban_check_result":0,"banned":0},"published":1,"hidden":0,"rtime32_visibility_start":0,"rtime32_visibility_end":0,"broadcaster_accountid":0,"follower_count":0,"ignore_count":0,"forum_topic_id":"569289127298899551","rtime32_last_modified":1782460958,"news_post_gid":"0","rtime_mod_reviewed":1781622143,"featured_app_tagid":0,"referenced_appids":[],"build_id":0,"build_branch":"","unlisted":0,"rtime_created":1781615482,"votes_up":12541,"votes_down":125,"comment_type":"ForumTopic","gidfeature":"603032904253089164","gidfeature2":"569289127298899551"},{"gid":"526495718648578104","clan_steamid":"103582791475178324","event_name":"THE PLAY IT YOUR WAY UPDATE","event_type":14,"appid":3527290,"server_address":null,"server_password":null,"rtime32_start_time":1774890600,"rtime32_end_time":1774895401,"comment_count":0,"creator_steamid":"0","last_update_steamid":"0","event_notes":"see announcement body","jsondata":"{\"localized_subtitle\":[\"Custom runs, mini runs, checkpoints and chill campfires!\",null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_summary\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_title_image\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_capsule_image\":[\"ed7a1a530cc433de7ba5604115bbd2a7c497596b.png\",null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"bSaleEnabled\":false,\"sale_show_creator\":false,\"sale_sections\":[],\"sale_browsemore_text\":\"\",\"sale_browsemore_url\":\"\",\"sale_browsemore_color\":\"\",\"sale_browsemore_bgcolor\":\"\",\"localized_sale_header\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_sale_overlay\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_sale_product_banner\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_sale_product_mobile_banner\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_sale_logo\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"sale_font\":\"\",\"sale_background_color\":\"\",\"sale_header_offset\":530,\"referenced_appids\":[],\"bBroadcastEnabled\":false,\"broadcastChatSetting\":\"hide\",\"default_broadcast_title\":\"#Broadcast_default_title_dev\",\"localized_broadcast_title\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_broadcast_left_image\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"localized_broadcast_right_image\":[null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\"broadcast_whitelist\":[],\"bScheduleEnabled\":false,\"scheduleEntries\":[]}","announcement_body":{"gid":"526495718648578105","clanid":"45656916","posterid":"0","headline":"THE PLAY IT YOUR WAY UPDATE","posttime":1774890604,"updatetime":1774890604,"body":"[h2]THE PLAY IT YOUR WAY UPDATE![\/h2][p]Duck and cover, scouts! Major update coming your way with a lot of long-requested quality of life features \u2026 but we snuck in some weirder stuff, too.[\/p][previewyoutube=\"6GGPZWjAt6I;full\"][\/previewyoutube][p]The trailer explains all.\n[\/p][h2]MAJOR FEATURES \u02d0PEAKpoint\u02d0[\/h2][p][\/p][h3]CUSTOM RUNS![\/h3][p]You can now modify all sorts of things about your run, such as individual difficulty settings, the presence of certain gameplay hazards, which items spawn in luggage\u2026 and more! Explore this menu at the Boarding Kiosk in the Airport. There are a few fun surprises for you, [i]and more to come![\/i]\u00a0[\/p][p][b][i](Note: Achievements are disabled while using the Custom Run feature)[\/i][\/b][\/p][p][img src=\"{STEAM_CLAN_IMAGE}\/45656916\/14e43286b2d6c2a592839176f176e126318e4ddb.png\"][\/img][img src=\"{STEAM_CLAN_IMAGE}\/45656916\/30db69834b5c08c26cef0fdea36385a092733318.png\"][\/img][\/p][h3]MINI RUNS!![\/h3][p]As part of the Custom Run menu, we\u2019ve introduced Mini Runs that let you play a single biome of today\u2019s map. If you haven\u2019t got time for a full run in the evenings, this mode is for you![\/p][p][img src=\"{STEAM_CLAN_IMAGE}\/45656916\/aa6450ee3442e498630c5c0f03ff46c5ef84fbd9.png\"][\/img][\/p][p][\/p][h3]CAMPFIRE AUTOSAVES!!! [\/h3][p]Our top scientists have been hard at work figuring out how to let you continue from your most recent campfire. And we\u2019re pleased to report we\u2019ve finally cracked the code. You can now leave an expedition and continue it later! The campfire autosave lasts until you win, lose, or start a new expedition.[\/p][p][b][i](Note: If the game updates and we remove the map you were playing on, your save is gonna get erased. Sorry! Use it or lose it!)[\/i][\/b][\/p][p][img src=\"{STEAM_CLAN_IMAGE}\/45656916\/5339fbdab4b000922711d5c9a0923ed76ea0ae6a.png\"][\/img][\/p][h3]CHILL CAMPFIRES [\/h3][p]You can now hang out as long as you like by a campfire without gaining hunger or the fog progressing. It will not extinguish until any scout leaves.[\/p][p][img src=\"{STEAM_CLAN_IMAGE}\/45656916\/1584d269aa04dc337ff43fcf9bf79d52dbb7864c.png\"][\/img][\/p][h2]MINOR FEATURES\u00a0\u02d0PEAKblush\u02d0[\/h2][p][\/p][h3]Zombie Phobia Mode [\/h3][p]Everyone likes zombies\u2026 okay, maybe most people hate them. But some people really, [i]really[\/i] hate them. If you can\u2019t stand the idea of your friend\u2019s brain being taken over by mushrooms, we\u2019ve introduced an alternative aesthetic for the mushroom enemies in the Roots that hopefully squicks you out less. As always, we\u2019re very open to feedback on these sorts of accessibility options![\/p][p][\/p][p][b][i](Note: Zombies can also be removed entirely in the new Custom Run settings, or, as always, by playing in Tenderfoot difficulty.)[\/i][\/b][\/p][p][img src=\"{STEAM_CLAN_IMAGE}\/45656916\/54819e49ad951906bdf788b4e8a9d1dfb08bbefd.gif\"][\/img][\/p][h2]BUGFIXES + BALANCE \u02d0PEAKsalute\u02d0[\/h2][p]\u02d0PEAKbingbong\u02d0 Achievements that need to be done in a single run will now maintain their progress if a player disconnects\/reconnects (such as Gourmand or Mycology badges)[\/p][p]\u02d0PEAKbingbong\u02d0 Fixed a long-standing issue where interacting with a rope shooter's rope immediately after it was fired could cause a division by zero, causing chaotic behaviour, including locking the player's controls or sending them to the void.[\/p][p]\u02d0PEAKbingbong\u02d0 Fixed issue where sometimes scouts would not revive when reconnecting in cases where they should have.[\/p][p]\u02d0PEAKbingbong\u02d0 Made the endgame scout report work properly after disconnecting and reconnecting to a game.[\/p][p]\u02d0PEAKbingbong\u02d0 Audio sliders and kick button will now show up immediately when a new player joins without needing to re-open the menu.[\/p][p]\u02d0PEAKbingbong\u02d0 Scouts that were skeletons when they disconnected will still be skeletons when they reconnect.[\/p][p]\u02d0PEAKbingbong\u02d0 Fixed a bug where Player 3 and Player 4 would spawn in the same location.[\/p][p]\u02d0PEAKbingbong\u02d0 Rescue Hook now doesn't put you in a ragdolled state for as long, making it easier to use.[\/p][p][\/p][h3][i]If you're only interested in the game and not in merch or other stuff, you can stop reading here[\/i]![\/h3][p][\/p][p][img src=\"{STEAM_CLAN_IMAGE}\/45656916\/68a1cdf48ec9cbfb5b0ea76cc13cafae58c1c2e7.gif\"][\/img][\/p][p][\/p][h2]MERCH [\/h2][p]We have some more merch dropping together with Makeship and YouTooz![\/p][p][\/p][h3]SCOUTMASTER MYRES[\/h3][p]We've seen the fanart and tweets.... yes even the thirsty ones! [\/p][p][url=\"https:\/\/www.makeship.com\/products\/scoutmaster-myres-plushie\"]Get the Scoutmaster Myres plush here.[\/url][\/p][p][img src=\"{STEAM_CLAN_IMAGE}\/45656916\/9974a1ab4cbf148de9f40e7c3b150822b2c372d7.png\"][\/img][\/p][h3]BING BONG KEYRING[\/h3][p]Your dream of having your very own Bingbubu is real![\/p][p][url=\"https:\/\/youtooz.com\/products\/bing-bong-keychain\"]Pre-order on YouTooz here.[\/url][\/p][h3][img src=\"{STEAM_CLAN_IMAGE}\/45656916\/c36c0535ce5e7e33a6c35ca2a22dfd3d34285bd8.png\"][\/img][\/h3][p][b]See the other merch we have [url=\"https:\/\/landfall.se\/merch\"]here.[\/url][\/b][\/p][p][\/p][h2]SCOUTS IN FORTNITE[\/h2][p]The scouts dropped in Tomato Town this weekend! [\/p][p]THEY EVEN MADE A BING BONG GUN WRAP![\/p][p][img src=\"{STEAM_CLAN_IMAGE}\/45656916\/1c5d7488a311e2b9dd7c381fc7b490896aeb6484.png\"][\/img][\/p][h2]BUGS OR FEEDBACK?[\/h2][p]As per usual, please report any bugs in the Steam forums or reach out to support@landfall.se so we can help you out. Some of our more common troubleshooting stuff can be found [url=\"https:\/\/landfall.se\/peak-faq\"]here.[\/url] [\/p][p][\/p][h3]Climb away![\/h3][h3]\/The Peak Team[\/h3]","commentcount":535,"tags":["mod_reviewed","ModAct_1888166638_1774892023_0"],"language":0,"hidden":0,"forum_topic_id":"805721252880771482","event_gid":"526495718648578104","voteupcount":12046,"votedowncount":301,"ban_check_result":0,"banned":0},"published":1,"hidden":0,"rtime32_visibility_start":0,"rtime32_visibility_end":0,"broadcaster_accountid":0,"follower_count":0,"ignore_count":0,"forum_topic_id":"805721252880771482","rtime32_last_modified":1782456512,"news_post_gid":"0","rtime_mod_reviewed":1774892023,"featured_app_tagid":0,"referenced_appids":[],"build_id":22169069,"build_branch":"","unlisted":0,"rtime_created":0,"votes_up":12046,"votes_down":301,"comment_type":"ForumTopic","gidfeature":"603032904253089164","gidfeature2":"805721252880771482"},{"gid":"679628250084802935","clan_steamid":"103582791475178324","event_name":"Patch Notes 1.64.a","event_type":12,"appid":3527290,"server_address":null,"server_password":null,"rtime32_start_time":1782333794,"rtime32_end_time":0,"comment_count":0,"creator_steamid":"0","last_update_steamid":"0","event_notes":"see announcement body","jsondata":"[]","announcement_body":{"gid":"679628250084802936","clanid":"45656916","posterid":"0","headline":"Patch Notes 1.64.a","posttime":1782333794,"updatetime":1782333794,"body":"This is just another small patch with some minor changes to map generation! Although most of our work continues to be on the final biome update, we'll be making some other updates in the coming weeks, prior to the final update, to address some pressing community concerns around game balance, performance, and mod support. Don't worry, we see your bug reports on Discord and are still working on them! We have some relatively big under-the-hood changes to the engine on the way as well, so the next big patch will be on the beta branch first to ensure it's extra stable and give modders an opportunity to update their mods before it goes live. If you'd like to help us test these changes, be sure to check in on the official PEAK Discord from time to time! When the patch is ready for beta, we'll let everyone know there. You can find the link to our Discord at the bottom of this post.\n\nChanges for this patch:\n* Removed BombBeetles and TornadoHell from the list of potential variants for Roots and Mesa\n* There should be slightly less spore clouds on some of the more challenging Roots variants (this is a temporary change to make these variants slightly less brutal while we look into making more holistic changes around Roots balance)","commentcount":51,"tags":["patchnotes","mod_reviewed","ModAct_1751692459_1782336162_0"],"language":0,"hidden":0,"forum_topic_id":"567038259400627208","event_gid":"679628250084802935","voteupcount":1393,"votedowncount":46,"ban_check_result":0,"banned":0},"published":1,"hidden":0,"rtime32_visibility_start":0,"rtime32_visibility_end":0,"broadcaster_accountid":0,"follower_count":0,"ignore_count":0,"forum_topic_id":"567038259400627208","rtime32_last_modified":1782461386,"news_post_gid":"0","rtime_mod_reviewed":1782336163,"featured_app_tagid":0,"referenced_appids":[],"build_id":0,"build_branch":"","unlisted":0,"rtime_created":1782333794,"votes_up":1392,"votes_down":46,"comment_type":"ForumTopic","gidfeature":"603032904253089164","gidfeature2":"567038259400627208"}],"EventWebRowEmbed":{"bPreLoaded":true,"announcementGIDList":["715655868018854131","526495718648578105"],"last_update_event":{"rtime":1782333794,"event_gid":"679628250084802935","announcement_gid":"679628250084802936","clan_account_id":45656916}}};
						</script>
					

					<div data-featuretarget="events-row"></div>
				
								
				
				


									<div id="contentForThisGame_ctn">
					</div>
									<div data-panel="{&quot;type&quot;:&quot;PanelGroup&quot;}" id="aboutThisGame" class="game_page_autocollapse" style="max-height: 850px;">
						<div id="game_area_description" class="game_area_description">
							<h2>Bu Oyun Hakkında</h2>
							<p class="bb_paragraph" >En ufak bir hatanın bile seni kıyamete sürükleyebileceği PEAK, iş birliğine dayalı bir tırmanma oyunudur. Kaybolmuş doğa izcisi olarak tek başına veya bir grupla oyna. Gizemli bir adadan kurtulmanın tek yolu, merkezdeki dağa tırmanmak. ZİRVEYE ulaşabilecek misin?</p><p class="bb_paragraph" ><span class="bb_img_ctn"><video class="bb_img" autoplay muted loop playsinline poster="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/e82d11d9221b2a65adeb68d8cdbc3bd2.poster.avif?t=1775581133" width=600 height=170 ><source src="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/e82d11d9221b2a65adeb68d8cdbc3bd2.webm?t=1775581133" type="video/webm; codecs=vp9"><source src="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/e82d11d9221b2a65adeb68d8cdbc3bd2.mp4?t=1775581133" type="video/mp4"></video></span></p><p class="bb_paragraph" ><strong>İŞ BİRLİĞİ YAP</strong></p><p class="bb_paragraph" >Yardım mı Lazım? Her gün değişen dağa tırmanabilmen için arkadaşlarına güvenmen gerekecek. Kaya çıkıntılarına tırmanmak için birbirinize destek olun veya ip ve tırmanma çivisi yerleştirerek sizden sonra gelenler için yolu kolaylaştırın.</p><p class="bb_paragraph" ></p><p class="bb_paragraph" ><span class="bb_img_ctn"><video class="bb_img" autoplay muted loop playsinline poster="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/846e9fa10908c6ffe7ce91c6c9e7a937.poster.avif?t=1775581133" width=600 height=170 ><source src="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/846e9fa10908c6ffe7ce91c6c9e7a937.webm?t=1775581133" type="video/webm; codecs=vp9"><source src="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/846e9fa10908c6ffe7ce91c6c9e7a937.mp4?t=1775581133" type="video/mp4"></video></span></p><p class="bb_paragraph" ><strong>TIRMAN</strong></p><p class="bb_paragraph" >Dağın Acıması Yoktur! ZİRVEYE ulaşmak için kendine has ölüm tehlikeleriyle dolu 4 farklı biyomu tırmanarak geç. Hayatta kalmak için normalde yemeyeceğin yiyecekler yağmalaman ve yaralarına dikkat etmen gerekecek. Yaşadığın her sorun takatini azaltarak tırmanmanı zorlaştırır.</p><p class="bb_paragraph" ></p><p class="bb_paragraph" ><span class="bb_img_ctn"><video class="bb_img" autoplay muted loop playsinline poster="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/5693882416756ce57898b4b2f774245d.poster.avif?t=1775581133" width=600 height=170 ><source src="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/5693882416756ce57898b4b2f774245d.webm?t=1775581133" type="video/webm; codecs=vp9"><source src="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/5693882416756ce57898b4b2f774245d.mp4?t=1775581133" type="video/mp4"></video></span></p><p class="bb_paragraph" ><strong>HAYATTA KAL</strong></p><p class="bb_paragraph" >En Kötü Duruma Hazırlan: Enerji içeceği, tırmanma çivisi ve gizemli Anti İp gibi birçok kullanışlı hayatta kalma eşyasını keşfet. Elindeki tüm avantajları kullanmadan ZİRVEYE ulaşma şansın yok.</p><p class="bb_paragraph" ></p><p class="bb_paragraph" ><span class="bb_img_ctn"><video class="bb_img" autoplay muted loop playsinline poster="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/d727ff6feeb578b5f07bf160882ed15f.poster.avif?t=1775581133" width=600 height=172 ><source src="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/d727ff6feeb578b5f07bf160882ed15f.webm?t=1775581133" type="video/webm; codecs=vp9"><source src="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/d727ff6feeb578b5f07bf160882ed15f.mp4?t=1775581133" type="video/mp4"></video></span></p><p class="bb_paragraph" ></p><p class="bb_paragraph" ><strong>HER GÜN YENİ BİR ADA</strong></p><p class="bb_paragraph" >Oyunun haritası 24 saatte bir değişir! Her gün yeni düzeni dene veya aynı adayı bir günde birkaç defa deneyerek o adaya hükmetmeye çalış.</p><p class="bb_paragraph" ></p><p class="bb_paragraph" ><span class="bb_img_ctn"><video class="bb_img" autoplay muted loop playsinline poster="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/237f4cb42de69c582fbb73ba5f8cf462.poster.avif?t=1775581133" width=600 height=170 ><source src="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/237f4cb42de69c582fbb73ba5f8cf462.webm?t=1775581133" type="video/webm; codecs=vp9"><source src="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/237f4cb42de69c582fbb73ba5f8cf462.mp4?t=1775581133" type="video/mp4"></video></span></p><p class="bb_paragraph" ><strong>ROZET KAZAN</strong></p><p class="bb_paragraph" >Deneyimli Bir İzci: Kazanabileceğin birçok rozet ve kilidini açabileceğin birçok görünümle hayatta kalma becerilerini sergile.</p><p class="bb_paragraph" ></p><p class="bb_paragraph" ><span class="bb_img_ctn"><video class="bb_img" autoplay muted loop playsinline poster="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/270bbff7baa4cfb700c04a6c09085cd1.poster.avif?t=1775581133" width=600 height=170 ><source src="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/270bbff7baa4cfb700c04a6c09085cd1.webm?t=1775581133" type="video/webm; codecs=vp9"><source src="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/270bbff7baa4cfb700c04a6c09085cd1.mp4?t=1775581133" type="video/mp4"></video></span></p><p class="bb_paragraph" ><strong>DOSTLARLA TIRMANMAK DAHA EĞLENCELİ</strong></p><p class="bb_paragraph" >PEAK'te yalnızca arkadaşlarınla çok oyunculu oynayabilirsin. Steam üzerinden en fazla üç izciyi daha davet ederek onlarla birlikte tırmanış yapabilirsin veya çok cesursan dağa tek başına kafa tutabilirsin!</p><p class="bb_paragraph" ></p><p class="bb_paragraph" ><span class="bb_img_ctn"><video class="bb_img" autoplay muted loop playsinline poster="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/738321f1bc4d3b1d1dddb55463c6e2eb.poster.avif?t=1775581133" width=600 height=172 ><source src="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/738321f1bc4d3b1d1dddb55463c6e2eb.webm?t=1775581133" type="video/webm; codecs=vp9"><source src="https://shared.fastly.steamstatic.com/store_item_assets/steam/apps/3527290/extras/738321f1bc4d3b1d1dddb55463c6e2eb.mp4?t=1775581133" type="video/mp4"></video></span></p><p class="bb_paragraph" ></p><p class="bb_paragraph" ><strong>ÖZELLİKLER</strong></p><ul class="bb_ul"><li><p class="bb_paragraph" >Toplamda 4 arkadaşınla birlikte tırmanış yap</p></li></ul><ul class="bb_ul"><li><p class="bb_paragraph" >Mesafeye bağlı sohbeti kullanarak iletişim kur </p></li></ul><ul class="bb_ul"><li><p class="bb_paragraph" >Zirveye giden yolda 4 farklı biyoma tırman</p></li><li><p class="bb_paragraph" >Normalde yemeyeceğin birçok yiyecek</p></li><li><p class="bb_paragraph" >Birçok farklı tırmanış eşyası</p></li><li><p class="bb_paragraph" >Kamp ateşi ve şekerleme</p></li><li><p class="bb_paragraph" >Karakter özelleştirme</p></li><li><p class="bb_paragraph" >İş birliğine dayalı çevrim içi ve çevrim dışı tek oyunculu</p></li><li><p class="bb_paragraph" >Hayaletler</p></li></ul><p class="bb_paragraph" > </p>						</div>
					</div>
				
				
				
